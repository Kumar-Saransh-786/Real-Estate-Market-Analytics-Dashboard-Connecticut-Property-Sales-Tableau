            </column>
            <column datatype='string' name='[Property.Type]' role='dimension' type='nominal' />
            <column datatype='string' name='[Residential.Type]' role='dimension' type='nominal' />
            <column datatype='real' name='[Sale.Amount]' role='measure' type='quantitative' />
            <column datatype='string' name='[Town]' role='dimension' type='nominal' />
            <column-instance column='[Date.Recorded]' derivation='Month' name='[mn:Date.Recorded:ok]' pivot='key' type='ordinal' />
            <column-instance column='[List.Year]' derivation='None' name='[none:List.Year:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Residential.Type]' derivation='None' name='[none:Residential.Type:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_184084676691566594]' derivation='User' name='[usr:Calculation_184084676691566594:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' />
            </column-instance>
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0p8kduw0me3dyq1a08nzg0vanntb].[Action (MONTH(Date.Recorded))]'>
            <groupfilter function='level-members' level='[mn:Date.Recorded:ok]' user:ui-action-filter='[Action2_EE1C995736824A33B2BCE1DC33543FED]' user:ui-enumeration='all' user:ui-marker='enumerate' />
