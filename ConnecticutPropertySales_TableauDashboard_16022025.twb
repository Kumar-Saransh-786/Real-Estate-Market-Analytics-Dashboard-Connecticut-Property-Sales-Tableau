    <worksheet name='YOY Price Growth'>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_dataset_Real_Estate_Sales_2001_2022' name='federated.0p8kduw0me3dyq1a08nzg0vanntb' />
          </datasources>
          <datasource-dependencies datasource='federated.0p8kduw0me3dyq1a08nzg0vanntb'>
            <column caption='Price Growth %' datatype='real' name='[Calculation_184084676698931203]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(MEDIAN(IF [List.Year] = 2022 THEN [Sale.Amount] END) - &#13;&#10; MEDIAN(IF [List.Year] = 2002 THEN [Sale.Amount] END)) &#13;&#10; / MEDIAN(IF [List.Year] = 2002 THEN [Sale.Amount] END)' />
            </column>
            <column datatype='date' name='[Date.Recorded]' role='dimension' type='ordinal' />
            <column datatype='integer' name='[List.Year]' role='dimension' type='quantitative' />
            <column datatype='string' name='[Property.Type (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[Property.Type]' new-bin='true'>
                <bin default-name='false' value='&quot;Commercial&quot;'>
                  <value>&quot;Commercial&quot;</value>
                  <value>&quot;Four Family&quot;</value>
                  <value>&quot;Industrial&quot;</value>
                  <value>&quot;Public Utility&quot;</value>
                  <value>&quot;Three Family&quot;</value>
                  <value>&quot;Two Family&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Residential&quot;'>
                  <value>&quot;Apartments&quot;</value>
                  <value>&quot;Condo&quot;</value>
                  <value>&quot;Residential&quot;</value>
                  <value>&quot;Single Family&quot;</value>
                </bin>
                <bin default-name='true' value='&quot;Vacant Land&quot;'>
                  <value>&quot;Vacant Land&quot;</value>
                </bin>
              </calculation>
            </column>
            <column datatype='string' name='[Property.Type]' role='dimension' type='nominal' />
            <column datatype='string' name='[Residential.Type]' role='dimension' type='nominal' />
            <column datatype='real' name='[Sale.Amount]' role='measure' type='quantitative' />
            <column datatype='string' name='[Town]' role='dimension' type='nominal' />
            <column-instance column='[Date.Recorded]' derivation='Month' name='[mn:Date.Recorded:ok]' pivot='key' type='ordinal' />
            <column-instance column='[List.Year]' derivation='None' name='[none:List.Year:ok]' pivot='key' type='ordinal' />
            <column-instance column='[List.Year]' derivation='None' name='[none:List.Year:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Property.Type]' derivation='None' name='[none:Property.Type:nk]' pivot='key' type='nominal' />
