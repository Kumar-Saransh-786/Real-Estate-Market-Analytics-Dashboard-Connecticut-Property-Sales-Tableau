      <column datatype='integer' name='[Assessed.Value]' role='measure' type='quantitative' />
      <column caption='Year Over Year Appreciation Rate' datatype='real' name='[Calculation_184084676691566594]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(MEDIAN([Sale.Amount]) - LOOKUP(MEDIAN([Sale.Amount]), -1)) &#13;&#10;/ LOOKUP(MEDIAN([Sale.Amount]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Price Growth %' datatype='real' name='[Calculation_184084676698931203]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(MEDIAN(IF [List.Year] = 2022 THEN [Sale.Amount] END) - &#13;&#10; MEDIAN(IF [List.Year] = 2002 THEN [Sale.Amount] END)) &#13;&#10; / MEDIAN(IF [List.Year] = 2002 THEN [Sale.Amount] END)' />
      </column>
      <column caption='Sale vs Assessed Ratio' datatype='real' name='[Calculation_2250955434534203393]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sale.Amount]) / SUM([Assessed.Value])' />
      </column>
      <column caption='Donut chart' datatype='integer' name='[Calculation_2250955434595057666]' role='measure' type='quantitative'>
