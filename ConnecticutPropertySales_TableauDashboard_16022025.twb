          </datasources>
          <datasource-dependencies datasource='federated.0p8kduw0me3dyq1a08nzg0vanntb'>
            <column caption='Year Over Year Appreciation Rate' datatype='real' name='[Calculation_184084676691566594]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(MEDIAN([Sale.Amount]) - LOOKUP(MEDIAN([Sale.Amount]), -1)) &#13;&#10;/ LOOKUP(MEDIAN([Sale.Amount]), -1)'>
                <table-calc ordering-type='Rows' />
              </calculation>
